<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NEET Insight — Sign In</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    html, body { margin: 0; padding: 0; }
    body {
      background: #F4F7FE;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      background-image:
        radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.08) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(255, 156, 0, 0.08) 0px, transparent 50%);
    }
    .login-card {
      background: #ffffff;
      border-radius: 24px;
      box-shadow: 0 20px 60px rgba(20, 25, 70, 0.08), 0 2px 6px rgba(20, 25, 70, 0.04);
      padding: 3rem 2.5rem;
      width: 100%;
      max-width: 440px;
    }
    .brand-logo {
      width: 64px;
      height: 64px;
      border-radius: 18px;
      background: linear-gradient(135deg, #FF9C00, #FFC048);
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      font-weight: 800;
      margin: 0 auto 1.25rem;
      box-shadow: 0 10px 24px rgba(255, 156, 0, 0.35);
    }
    .brand-title {
      font-weight: 800;
      font-size: 1.6rem;
      text-align: center;
      color: #1B1C31;
      letter-spacing: -0.02em;
    }
    .brand-subtitle {
      text-align: center;
      color: #707EAE;
      font-size: 0.92rem;
      margin: 0.35rem 0 2rem;
    }
    .form-label {
      font-weight: 600;
      color: #1B1C31;
      font-size: 0.82rem;
      margin-bottom: 0.45rem;
      letter-spacing: 0.02em;
    }
    .form-control {
      border-radius: 12px;
      border: 1.5px solid #E2E8F0;
      padding: 0.75rem 1rem;
      font-size: 0.95rem;
      transition: all 0.15s ease;
    }
    .form-control:focus {
      border-color: #6366F1;
      box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
      outline: none;
    }
    .btn-primary-custom {
      background: #6366F1;
      border: none;
      color: #ffffff;
      font-weight: 600;
      padding: 0.8rem 1rem;
      border-radius: 12px;
      width: 100%;
      font-size: 0.95rem;
      transition: all 0.15s ease;
      margin-top: 0.5rem;
    }
    .btn-primary-custom:hover {
      background: #4F46E5;
      transform: translateY(-1px);
      box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
    }
    .alert-custom {
      background: #FEE2E2;
      color: #B91C1C;
      border-radius: 12px;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      margin-bottom: 1.25rem;
      border: 1px solid #FECACA;
      font-weight: 500;
    }
    .footer-note {
      text-align: center;
      color: #A3AED0;
      font-size: 0.78rem;
      margin-top: 1.75rem;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="brand-logo">N</div>
    <div class="brand-title">NEET Insight</div>
    <div class="brand-subtitle">Test Analysis & Performance Management</div>

    <% if (error) { %>
      <div class="alert-custom"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="mb-3">
        <label class="form-label">EMAIL ADDRESS</label>
        <input type="email" name="email" class="form-control" placeholder="you@example.com" required autocomplete="username" />
      </div>
      <div class="mb-3">
        <label class="form-label">PASSWORD</label>
        <input type="password" name="password" class="form-control" placeholder="Enter your password" required autocomplete="current-password" />
      </div>
      <button type="submit" class="btn-primary-custom">Sign In</button>
    </form>

    <div class="footer-note">Default admin: dipanshuydvofficial@gmail.com</div>
  </div>
</body>
</html>
